# --- Database ---
DB_USER=name
DB_PASS=your_password
DB_HOST=localhost
# Used by services running on the host (e.g. the Go application)
DB_PORT=3306
DB_NAME=prod_db
DB_ROOT_PASS=your_password

# --- Network Settings ---
# Required for Docker containers to access host services
# Run once on Linux:
# sudo ufw allow from 172.16.0.0/12 to any port <DEV_APP_PORT> proto tcp
# sudo ufw allow from 172.16.0.0/12 to any port <PROD_APP_PORT> proto tcp
APP_PORT=8080
# Base URL used by Docker containers (e.g. Selenium tests)
# to access the application running on the host
APP_URL=http://host.docker.internal:${APP_PORT}

# --- SELENIUM ---
# Port exposed on the host to access the Selenium container
# Used by services running on the host (e.g. the Go application)
SELENIUM_SERVER_PORT=4444
# URL used by the ui-tests container to reach the Selenium server inside the Docker network 
SELENIUM_SERVER_URI=http://selenium-chrome:4444

# --- Docs publishing ---
# Path where the CI job "publish_docs" uploads generated documentation via SCP.
# This directory is mounted into the Apache container that simulates a docs server.
DOCS_PATH=/opt/my-app-go/godoc
# Port used by the Apache container to serve documentation
APACHE_PORT=8082

# --- Compose Project Name ---
# Docker Compose project name used to isolate containers, networks and volumes 
COMPOSE_PROJECT_NAME=my-app-go-prod